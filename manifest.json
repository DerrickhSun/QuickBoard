{
    "description": "A simple extension that creates a taskbar along the top to save copied elements.",
    "version": "1.0",
    "manifest_version": 3,
    "name": "QuickBoard",
    "icons": {
        "600": "icons/clipboard-600.png"
    },
    "permissions": [
        "activeTab",
        "storage",
        "downloads"
    ],
    "host_permissions": [
        "https://*/*"
    ],
    "background": {
        "service_worker": "background.js",
        "scripts": ["background.js"]
    },
    "content_scripts": [
        {
            "matches": ["https://*/*"],
            "js": ["content_scripts/taskbar-shared.js", "content_scripts/scroll_elements.js", "content_scripts/content.js"],
            "run_at": "document_idle"
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "derrick.han.sun@gmail.com",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "action": {
        "default_title": "Taskbar",
        "default_icon": "icons/clipboard-600.png",
        "theme_icons": [
        {
            "light": "icons/clipboard-600.png",
            "dark": "icons/clipboard-600.png",
            "size": 600
        }
        ]
    },
    "web_accessible_resources": [
        {
            "resources": ["icons/clipboard-600.png", "icons/clipboard-600-light.png"],
            "matches": ["<all_urls>"]
        }
    ]
}